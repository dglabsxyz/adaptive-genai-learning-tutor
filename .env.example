GENAI_RESEARCH_DIR=./genai_research
TUTOR_DATA_DIR=./data
TUTOR_ENV=local
TUTOR_AUTH_MODE=local
TUTOR_LOCAL_TENANT_ID=local
TUTOR_LOCAL_USER_ID=demo-learner
TUTOR_LOCAL_ROLE=learner
TUTOR_CORS_ORIGINS=*
TUTOR_REQUEST_BODY_LIMIT_BYTES=64000
# Graph checkpointer: memory (tests), sqlite (single instance, default), or
# postgres (multi-instance / horizontal scale; requires DATABASE_URL + the
# optional `postgres` dependency extra).
TUTOR_GRAPH_CHECKPOINTER_BACKEND=sqlite
# Postgres connection string for the postgres checkpointer. Leave unset for sqlite/memory.
# DATABASE_URL=postgresql://user:password@host:5432/postgres
TUTOR_RATE_LIMIT_ENABLED=true
TUTOR_RATE_LIMIT_BACKEND=sqlite
TUTOR_RATE_LIMIT_WINDOW_SECONDS=60
TUTOR_RATE_LIMIT_CHAT=60
TUTOR_RATE_LIMIT_EXERCISE=40
TUTOR_RATE_LIMIT_ANSWER=80
TUTOR_RATE_LIMIT_SOURCE_SEARCH=120
TUTOR_RATE_LIMIT_MCP_TOOL=160
TUTOR_REPOSITORY_BACKEND=json
# Retrieval index: local TF-IDF (default), pgvector, or qwen (dense text-embedding-v4).
TUTOR_VECTOR_PROVIDER=local
TUTOR_VECTOR_TENANT_ID=
# LLM: deterministic (default) or qwen. Auto-selects qwen when QWEN_API_KEY is present.
TUTOR_LLM_PROVIDER=deterministic

# Qwen 3.7 family via DashScope (OpenAI-compatible). Set QWEN_API_KEY to enable the
# LLM provider, Qwen embeddings, and the infographic generation + Qwen3-VL verification.
QWEN_API_KEY=
QWEN_BASE_URL=https://dashscope-intl.aliyuncs.com/compatible-mode/v1
QWEN_LLM_MODEL=qwen3.7-plus
QWEN_EMBEDDING_MODEL=text-embedding-v4
QWEN_VL_MODEL=qwen3-vl-plus
QWEN_IMAGE_MODEL=qwen-image-2.0
LLM_TEMPERATURE=0.0
# Optional: let qwen3.7-plus add a short coaching note to graded answers.
TUTOR_LLM_COACHING=false

# Production JWT/OIDC auth. Keep blank for local header-based demos.
TUTOR_AUTH_JWT_ALGORITHMS=RS256,HS256
TUTOR_AUTH_JWT_SECRET=
TUTOR_AUTH_JWT_PUBLIC_KEY=
TUTOR_AUTH_ISSUER=
TUTOR_AUTH_AUDIENCE=
TUTOR_OIDC_DISCOVERY_URL=
TUTOR_OIDC_JWKS_URL=
TUTOR_OIDC_JWKS_CACHE_TTL_SECONDS=300
TUTOR_AUTH_USER_CLAIM=sub
TUTOR_AUTH_TENANT_CLAIM=tenant_id
TUTOR_AUTH_ROLE_CLAIM=role
TUTOR_AUTH_REQUIRE_TENANT_CLAIM=false

LANGSMITH_TRACING=false
LANGSMITH_API_KEY=
LANGSMITH_PROJECT=adaptive-genai-learning-tutor
# Required when a LangSmith service/org key spans multiple workspaces (else 403).
LANGSMITH_WORKSPACE_ID=

SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=
SUPABASE_ANON_KEY=

VITE_API_URL=http://localhost:8000

# --- Legacy variable names still accepted as fallbacks (canonical names above
# are preferred): APP_ENV -> TUTOR_ENV, CHECKPOINTER_BACKEND ->
# TUTOR_GRAPH_CHECKPOINTER_BACKEND, SUPABASE_KEY -> SUPABASE_SERVICE_ROLE_KEY,
# LANGCHAIN_* -> LANGSMITH_*, DASHSCOPE_API_KEY -> QWEN_API_KEY. ---
