# tutor-ui (Vite) configuration — copy to .env and adjust as needed.

# Backend API base URL.
#   Local dev against a local backend:  http://localhost:8000
#   Against the deployed backend:       https://adaptive-genai-learning-tutor-production.up.railway.app
VITE_API_URL=http://localhost:8000

# Tenant id sent as the x-tutor-tenant-id header. MUST be the seeded UUID when the
# backend runs the Supabase repository (the deployed/prod backend); any value works
# for a local json backend.
VITE_TUTOR_TENANT_ID=0507cc0e-4a9f-4468-ab32-b56bd87fc97d

# Default demo learner + role. Role can be switched in the UI (learner | educator | admin).
VITE_TUTOR_LEARNER_ID=demo-learner
VITE_TUTOR_ROLE=learner

# Client request timeout in ms. Deep-agent chat turns are slow; keep this generous.
VITE_REQUEST_TIMEOUT_MS=90000
